# AgroFeed CMS - Environment Variables for Amplify
# Copy these values to AWS Amplify Console

# ============================================
# AWS Configuration
# ============================================

# AWS Region
VITE_AWS_REGION=us-east-1

# ============================================
# AWS Cognito Configuration
# ============================================

VITE_AWS_COGNITO_USER_POOL_ID=us-east-1_JxtucAU3s
VITE_AWS_COGNITO_CLIENT_ID=4bp3ron4t3v2n1q8qvu2j795ov
VITE_AWS_COGNITO_IDENTITY_POOL_ID=us-east-1:7d4e0b0c-2a44-4be1-94c6-1c73af02e000
VITE_AWS_COGNITO_DOMAIN=agrofeed.auth.us-east-1.amazoncognito.com

# ============================================
# AWS S3 Configuration
# ============================================

VITE_AWS_S3_BUCKET=agrofeed-content-agrofeed-536217686312
VITE_AWS_S3_REGION=us-east-1
VITE_AWS_S3_URL=https://agrofeed-content-agrofeed-536217686312.s3.us-east-1.amazonaws.com

# ============================================
# AWS DynamoDB Configuration
# ============================================

VITE_AWS_DYNAMODB_TABLE=agrofeed-content
VITE_AWS_DYNAMODB_REGION=us-east-1

# ============================================
# IAM Credentials (Add in Amplify Console)
# ============================================
# Get these from: AWS Console → IAM → Users → Security credentials
# ⚠️ DO NOT commit these to Git!

VITE_AWS_ACCESS_KEY_ID=<ADD_IN_AMPLIFY_CONSOLE>
VITE_AWS_SECRET_ACCESS_KEY=<ADD_IN_AMPLIFY_CONSOLE>

# ============================================
# App Configuration
# ============================================

VITE_API_URL=
VITE_APP_NAME=AgroFeed CMS
VITE_APP_URL=http://localhost:5173

# ============================================
# Instructions for Amplify Deployment
# ============================================
#
# 1. Push code to Git (without .env file)
# 2. Go to AWS Amplify Console
# 3. Connect your repository
# 4. In "Environment variables" section, add:
#    - All variables above EXCEPT IAM credentials
#    - Add IAM credentials securely in Amplify Console
# 5. Deploy
#
# ⚠️ SECURITY:
# - Never commit VITE_AWS_ACCESS_KEY_ID or VITE_AWS_SECRET_ACCESS_KEY to Git
# - Store IAM credentials only in Amplify Console
# - Rotate access keys regularly
# ============================================
